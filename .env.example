SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Required by apps/api for Google OAuth token storage and server-side integration work.
SUPABASE_SERVICE_ROLE_KEY=

# Web/API local development.
API_PUBLIC_URL=http://localhost:8000 # FastAPI's public URL, used to construct server-side callback URLs
WEB_PUBLIC_URL=http://localhost:3000 # FastAPI URL used by the browser/web app
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: Google Calendar import for the web app.
# Use a Google OAuth client of type "Web application" with this redirect URI:
# http://localhost:8000/integrations/google/callback
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# Desktop can still persist Supabase config here:
# ~/Library/Application Support/Sway/supabase.json
# { "url": "https://YOURPROJECT.supabase.co", "anon_key": "eyJ...your-anon-key..." }
