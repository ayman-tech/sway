SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Required by apps/api for Google OAuth token storage and server-side integration work.
SUPABASE_SERVICE_ROLE_KEY=
# Required to encrypt each user's Google OAuth client secret and token.
# Generate with: cd apps/api && uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_CREDENTIALS_ENCRYPTION_KEY=

# FastAPI's public URL, used to construct server-side callback URLs.
API_PUBLIC_URL=http://localhost:8010
# Website origin used by FastAPI for CORS, OAuth returns, and public share links.
WEB_PUBLIC_URL=http://localhost:3010
# FastAPI URL used by the browser/web app.
NEXT_PUBLIC_API_URL=http://localhost:8010
# Same Supabase project URL and publishable key as above, exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Google Calendar OAuth callback. Users register this URI on their own Web OAuth client.
# http://localhost:8010/integrations/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8010/integrations/google/callback

# Desktop can still persist Supabase config here:
# ~/Library/Application Support/Sway/supabase.json
# { "url": "https://YOURPROJECT.supabase.co", "anon_key": "eyJ...your-anon-key...",
#   "api_url": "https://api.your-domain.com" }
